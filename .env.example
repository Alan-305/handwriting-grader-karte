# Firebase (Frontend - Vite)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Flask Backend
FLASK_ENV=development
FLASK_DEBUG=1
PORT=5001
# ローカル開発
CORS_ORIGINS=http://localhost:5173
# 試験運用デプロイ時は scripts/deploy-trial.sh が自動で Hosting URL を設定
# CORS_ORIGINS=https://handwriting-grader-karte.web.app,https://handwriting-grader-karte.firebaseapp.com

# 本番ビルド時のみ（deploy-trial.sh が Cloud Run URL を自動設定）
# VITE_API_BASE=

# Firebase Admin SDK (Backend)
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json
# 上記 JSON がある場合、setup-gcp-secrets が HGK_FIREBASE_SERVICE_ACCOUNT_JSON も登録（任意）

# AI APIs (Backend only - never expose to frontend)
# 本番: npm run setup:gcp-secrets で Secret Manager に登録し、Cloud Run は Secret 参照
HGK_ANTHROPIC_API_KEY=
HGK_GEMINI_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# gemini-2.0-flash は新規利用不可。2.5-flash 以上を指定してください。
# 手書き転記の空応答を避けるため lite 推奨（flash でも可）
GEMINI_MODEL=gemini-2.5-flash-lite
