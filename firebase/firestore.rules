rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isTeacher(teacherId) {
      return request.auth != null && request.auth.uid == teacherId;
    }

    // 招待された閲覧者か（生徒ドキュメントの viewerEmails に小文字メールが含まれるか）
    function isViewerOfStudentData(studentData) {
      return request.auth != null
        && request.auth.token.email != null
        && (request.auth.token.email.lower() in studentData.get('viewerEmails', []));
    }

    function isViewerOfStudent(studentId) {
      return isViewerOfStudentData(
        get(/databases/$(database)/documents/students/$(studentId)).data
      );
    }

    match /teachers/{teacherId} {
      allow read, write: if request.auth != null && request.auth.uid == teacherId;

      match /exam_materials/{materialId} {
        allow read, write: if request.auth != null && request.auth.uid == teacherId;
      }

      match /question_drafts/{draftId} {
        allow read, write: if request.auth != null && request.auth.uid == teacherId;
      }
    }

    match /students/{studentId} {
      // 閲覧者は read のみ。書き込みは担当教師だけ
      allow read: if isTeacher(resource.data.teacherId) || isViewerOfStudentData(resource.data);
      allow write: if isTeacher(resource.data.teacherId);
      allow create: if isTeacher(request.resource.data.teacherId);

      // 成果物（カルテ）は閲覧者にも公開（read のみ）
      match /karte_snapshots/{snapshotId} {
        allow read: if isTeacher(get(/databases/$(database)/documents/students/$(studentId)).data.teacherId)
          || isViewerOfStudent(studentId);
        allow write: if isTeacher(get(/databases/$(database)/documents/students/$(studentId)).data.teacherId);
      }

      match /stats/{statId} {
        allow read: if isTeacher(get(/databases/$(database)/documents/students/$(studentId)).data.teacherId)
          || isViewerOfStudent(studentId);
        allow write: if isTeacher(get(/databases/$(database)/documents/students/$(studentId)).data.teacherId);
      }

      // 面談記録は教師内部資料。閲覧者には公開しない
      match /interview_records/{recordId} {
        allow read, write: if isTeacher(get(/databases/$(database)/documents/students/$(studentId)).data.teacherId);
      }
    }

    match /target_universities/{universityId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /universities/{universityId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;

      match /exam_years/{yearId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }

      match /past_questions/{questionId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }
    }

    match /answer_sheet_templates/{templateId} {
      allow read, write: if isTeacher(resource.data.teacherId);
      allow create: if isTeacher(request.resource.data.teacherId);
    }

    match /tests/{testId} {
      allow read, write: if isTeacher(resource.data.teacherId);
      allow create: if isTeacher(request.resource.data.teacherId);

      match /questions/{questionId} {
        allow read, write: if isTeacher(get(/databases/$(database)/documents/tests/$(testId)).data.teacherId);
      }
    }

    match /sessions/{sessionId} {
      // 閲覧者は対象生徒の成果物のみ read 可。書き込みは担当教師だけ
      allow read: if isTeacher(resource.data.teacherId)
        || isViewerOfStudent(resource.data.studentId);
      allow write: if isTeacher(resource.data.teacherId);
      allow create: if isTeacher(request.resource.data.teacherId);

      match /question_results/{resultId} {
        allow read: if isTeacher(get(/databases/$(database)/documents/sessions/$(sessionId)).data.teacherId)
          || isViewerOfStudent(get(/databases/$(database)/documents/sessions/$(sessionId)).data.studentId);
        allow write: if isTeacher(get(/databases/$(database)/documents/sessions/$(sessionId)).data.teacherId);
      }

      match /print_artifacts/{artifactId} {
        allow read: if isTeacher(get(/databases/$(database)/documents/sessions/$(sessionId)).data.teacherId)
          || isViewerOfStudent(get(/databases/$(database)/documents/sessions/$(sessionId)).data.studentId);
        allow write: if isTeacher(get(/databases/$(database)/documents/sessions/$(sessionId)).data.teacherId);
      }
    }
  }
}
